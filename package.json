{
  "name": "playwright-mcp-allure",
  "version": "1.0.0",
  "description": "Playwright testing framework with MCP server and Allure reporter",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "allure:report": "node ./scripts/restore-allure-history.js && npx allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:send": "bash ./scripts/send-allure-report.sh",
    "allure:serve": "npm run allure:report && npx http-server ./allure-report -p 8000",
    "mcp:server": "node dist/mcp-server.js",
    "build": "tsc",
    "clean": "rm -rf dist allure-results allure-report"
  },
  "keywords": [
    "playwright",
    "testing",
    "mcp",
    "allure",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/pretty-formatter": "^3.2.0",
    "@playwright/test": "^1.40.0",
    "@types/chance": "^1.1.7",
    "@types/node": "^20.10.0",
    "allure-commandline": "^2.25.0",
    "allure-playwright": "^2.15.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@ngneat/falso": "^8.0.2",
    "chance": "^1.1.13",
    "chance.js": "^0.0.1"
  }
}
